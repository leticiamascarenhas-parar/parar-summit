<script>
  function iniciarContadores() {
    const section = document.querySelector('.summit-numbers');

    if (!(section instanceof HTMLElement)) return;
    if (section.dataset.ready === 'true') return;

    section.dataset.ready = 'true';

    const counters = Array.from(
      section.querySelectorAll('.counter')
    ).filter((item) => item instanceof HTMLElement);

    let animationFrames = [];

    function cancelarAnimacoes() {
      animationFrames.forEach((frame) => {
        cancelAnimationFrame(frame);
      });

      animationFrames = [];
    }

    function zerarContadores() {
      cancelarAnimacoes();

      counters.forEach((counter) => {
        counter.textContent = '0';
      });
    }

    function animarContadores() {
      cancelarAnimacoes();

      counters.forEach((counter) => {
        const target = Number(counter.dataset.target);
        const prefix = counter.dataset.prefix || '';
        const suffix = counter.dataset.suffix || '';
        const duration = 1600;
        const start = performance.now();

        function atualizar(now) {
          const progress = Math.min(
            (now - start) / duration,
            1
          );

          const easedProgress =
            1 - Math.pow(1 - progress, 3);

          const current = Math.floor(
            easedProgress * target
          );

          counter.innerHTML =
            prefix +
            current.toLocaleString('pt-BR') +
            (suffix ? `<span class="counter-suffix">${suffix}</span>` : '');

          if (progress < 1) {
            const frame = requestAnimationFrame(atualizar);
            animationFrames.push(frame);
          } else {
            counter.innerHTML =
              prefix +
              target.toLocaleString('pt-BR') +
              (suffix ? `<span class="counter-suffix">${suffix}</span>` : '');
          }
        }

        const frame = requestAnimationFrame(atualizar);
        animationFrames.push(frame);
      });
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          zerarContadores();
          animarContadores();
        } else {
          zerarContadores();
        }
      },
      {
        threshold: 0.35
      }
    );

    observer.observe(section);
  }

  iniciarContadores();

  document.addEventListener(
    'astro:page-load',
    iniciarContadores
  );
</script>