        { href: "https://www.renault.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/12.png", alt: "Renault" },
        { href: "https://frotas.localiza.com/", src: "https://institutoparar.com.br/wp-content/uploads/2025/09/LOGOS-LP-PARAR-SUMMIT-18.png", alt: "Localiza" },
        { href: "https://www.sempararempresas.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/5.png", alt: "Sem Parar" },
        { href: "https://ecxpay.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2026/04/ECX.png", alt: "ECX" },
      ],
    },
    {
      key: "patrocinadores-ouro",
      title: "Patrocinadores Ouro",
      logos: [
        { href: "https://www.valecard.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/9.png", alt: "ValeCard" },
        { href: "https://monacobr.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/LOGOS-LP-PARAR-SUMMIT-8.png", alt: "Monaco" },
        { href: "https://nearlocation.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/LOGOS-LP-PARAR-SUMMIT-1.png", alt: "Near Location" },
        { href: "https://www.arvalbrasil.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/LOGOS-LP-PARAR-SUMMIT-9.png", alt: "Arval" },
        { href: "https://www.movidafrotas.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/LOGOS-LP-PARAR-SUMMIT-4.png", alt: "Movida" },
