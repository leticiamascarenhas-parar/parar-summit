      title: "Realização",
      logos: [
        { href: "https://institutoparar.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/1.png", alt: "Logo PARAR", wide: true },
      ],
    },
    {
      key: "idealizacao",
      title: "Idealização",
      logos: [
        { href: "https://golfleet.com.br/", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/2.png", alt: "Logo Golfleet" },
      ],
    },
    {
      key: "patrocinadores-oficiais",
      title: "Patrocinadores Oficiais",
      logos: [
        { href: "https://www.gmfleet.com.br/pt-br/inicio.html", src: "https://institutoparar.com.br/wp-content/uploads/2025/07/3.png", alt: "GM Fleet" },
      ],
    },
    {
      key: "patrocinadores-diamante",
      title: "Patrocinadores Diamante",
