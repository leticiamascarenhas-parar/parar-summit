---
// Parceiros.astro
// Uso básico: <Parceiros />
// Uso customizado: <Parceiros tiers={meusTiers} />

export interface Logo {
  href: string;
  src: string;
  alt: string;
  wide?: boolean; // usa a mesma regra do .parar-logo-img (logo maior, ex: Realização)
}

export interface Tier {
  key: string;
  title: string;
  logos: Logo[];
  smallLogos?: boolean; // reduz max-height das logos (usado no Green Hub)
}

interface Props {
  tiers?: Tier[];
}

const {
  tiers = [
