---
// PararAwards.astro
// Uso básico: <PararAwards />
// Uso customizado: veja os Props abaixo

export interface Category {
  icon: "truck" | "users" | "shield";
  title: string;
  desc: string;
}

interface Props {
  logo?: string;
  bgImage?: string;
  eyebrow?: string;
  title?: string;
  ctaText?: string;
  ctaHref?: string;
  categoriesTitle?: string;
  categories?: Category[];
}

const {
  logo = "/images/parar-awards.png",
  bgImage = "/images/parar-awards-bg.png",
  eyebrow = "AWARDS 2025",
  title = "PARAR",
  ctaText = "Inscrições aqui",
  ctaHref = "https://conteudo.institutoparar.com.br/parar-awards-2026",
  categoriesTitle = "Categorias",
  categories = [
    {
      icon: "truck",
      title: "A Melhor Frota do Brasil",
      desc: "Reconhece a operação com os melhores indicadores de eficiência e resultado.",
    },
    {
      icon: "users",
      title: "O Melhor Gestor de Frotas do Brasil",
      desc: "Celebra a liderança que transforma pessoas, processos e desempenho.",
    },
    {
      icon: "shield",
      title: "A Frota Mais Segura do Brasil",
      desc: "Premia a excelência em segurança viária e prevenção de acidentes.",
    },
  ],
} = Astro.props;

const icons: Record<Category["icon"], string> = {
  truck: `<path d="M2 8h11v8H2z"/><path d="M13 11h4l3 3v2h-7z"/><circle cx="6" cy="18" r="1.6"/><circle cx="16.5" cy="18" r="1.6"/>`,
  users: `<circle cx="8.5" cy="8" r="3"/><path d="M2.5 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17" cy="9" r="2.4"/><path d="M15 13.2c2.4.3 4.3 2.3 4.5 4.8"/>`,
  shield: `<path d="M12 2 4 5v6c0 5 3.4 8.6 8 10 4.6-1.4 8-5 8-10V5z"/><path d="m8.5 12 2.3 2.3L15.5 9"/>`,
};
---

<section id="parar-awards" class="parar-awards max-md:px-4 max-md:py-14" style={`--bg-image: url(${bgImage});`}>
  <div class="pa-inner max-md:flex max-md:flex-col max-md:items-center max-md:justify-center max-md:gap-8">

    <div class="pa-left max-md:flex max-md:flex-col max-md:items-center max-md:text-center">
      <div class="pa-brand max-md:flex max-md:justify-center">
        <img class="pa-logo max-md:mx-auto" src={logo} alt={`${title} ${eyebrow}`} />
      </div>

      <div class="pa-copy max-md:text-center">
        <p>
          Anualmente, o Instituto PARAR promove um grande momento de
          premiação a fim de reconhecer profissionais, empresas e projetos
          que têm se destacado no cenário de gestão de frotas no Brasil.
        </p>
        <p>
          Em 2026, as inscrições ficam abertas até o dia
          <strong> 31 de agosto</strong>, e os vencedores serão anunciados
          durante o <strong>PARAR Summit 26</strong>, o evento mais relevante
          em Gestão de Frotas da América Latina.
        </p>
      </div>

      <a class="pa-cta max-md:mx-auto" href={ctaHref}>
        {ctaText}
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m13 6 6 6-6 6"/>
        </svg>
      </a>
    </div>

    <div class="pa-right max-md:flex max-md:flex-col max-md:items-center max-md:text-center">
      <div class="pa-cat-heading max-md:flex-col max-md:justify-center max-md:gap-3">
        <span class="pa-cat-icon">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 4h8v4a4 4 0 0 1-8 0z"/>
            <path d="M8 4H4v1a4 4 0 0 0 4 4"/>
            <path d="M16 4h4v1a4 4 0 0 1-4 4"/>
            <path d="M12 12v4"/>
            <path d="M9 20h6"/>
            <path d="M10 16h4l1 4H9z"/>
          </svg>
        </span>
        <h2>{categoriesTitle}</h2>
      </div>

      <ul class="pa-cat-list max-md:w-full max-md:items-stretch">
        {categories.map((c) => (
          <li class="pa-cat-card max-md:flex-col max-md:items-center max-md:text-center max-md:gap-4">
            <span class="pa-cat-card-icon" set:html={`<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${icons[c.icon]}</svg>`} />
            <div>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  .parar-awards {
    --bg: #0a0f1e;
    --card-bg: #101a30;
    --card-border: #1e2c4a;
    --gold: #dab462;
    --gold-soft: #f4c860;
    --ink-soft: #b9c2d6;
    font-family: 'Raleway', 'Arial', sans-serif;


    position: relative;
    background: var(--bg-image) center / cover no-repeat, var(--bg);
    padding: 90px 24px;
    font-family: 'Raleway', 'Arial', sans-serif;
    color: #fff;
  }

  /* véu escuro sobre a imagem de fundo, pra garantir legibilidade do texto */
  .parar-awards::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8, 12, 24, 0.88), rgba(8, 12, 24, 0.82));
    z-index: 0;
  }

  .pa-inner {
    position: relative;
    z-index: 1;
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: 72px;
    align-items: end;
  }

  /* ---------- Coluna esquerda ---------- */
  .pa-brand {
    margin-bottom: 34px;
  }

  .pa-logo {
    height: 168px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .pa-copy p {
    font-size: 16.5px;
    line-height: 1.75;
    color: var(--ink-soft);
    margin: 0 0 20px;
  }

  .pa-copy strong {
    color: var(--gold-soft);
    font-weight: 700;
  }

  .pa-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    padding: 16px 30px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--gold-soft), var(--gold));
    color: #201404;
    font-weight: 800;
    font-size: 15px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 10px 26px rgba(242, 184, 60, 0.28);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pa-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(242, 184, 60, 0.38);
  }

  .pa-cta svg {
    transition: transform 0.2s ease;
  }

  .pa-cta:hover svg {
    transform: translateX(3px);
  }

  /* ---------- Coluna direita ---------- */
  .pa-cat-heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 26px;
  }

  .pa-cat-icon {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 2px solid var(--gold);
    color: var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pa-cat-heading h2 {
    margin: 0;
    font-size: 28px;
    font-weight: 900;
    letter-spacing: 0.5px;
    color: var(--gold);
    text-transform: uppercase;
  }

  .pa-cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .pa-cat-card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 22px 24px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .pa-cat-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }

  .pa-cat-card-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: #0a1326;
    border: 1px solid var(--card-border);
    color: var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pa-cat-card h3 {
    margin: 0 0 6px;
    font-size: 17px;
    font-weight: 800;
    color: #fff;
  }

  .pa-cat-card p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  /* ---------- Responsivo ---------- */
  @media (max-width: 980px) {
    .pa-inner {
      grid-template-columns: 1fr;
      gap: 56px;
      align-items: center;
      justify-items: center;
      text-align: center;
    }

    .pa-left,
    .pa-right {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      width: 100%;
    }

    .pa-logo {
      margin: 0 auto;
    }

    .pa-copy p {
      text-align: center;
    }

    .pa-cta {
      margin-inline: auto;
    }

    .pa-cat-heading {
      justify-content: center;
    }

    .pa-cat-card {
      align-items: center;
      text-align: center;
      justify-content: center;
    }
  }

  @media (max-width: 520px) {
    .parar-awards {
      padding: 60px 18px;
    }
    .pa-logo {
      height: 128px;
    }
    .pa-cat-heading h2 {
      font-size: 22px;
    }
  }
</style>
