---
import { trilhas } from "../data/trilhas";
import TrilhaCard from "./TrilhaCard.astro";
---

<section class="trilhas-section" id="trilhas">
  <div class="trilhas-header">
    <img
      src="/images/trilhas/titulo/titulo-trilhas.png"
      alt="Trilhas Simultâneas"
      class="titulo-trilhas"
    />
  </div>

  <div class="tabs-wrapper">
    <button
      class="tabs-arrow tabs-arrow-left"
      type="button"
      aria-label="Ver trilhas anteriores"
    >
      ‹
    </button>

    <div class="tabs">
      {trilhas.map((trilha, index) => (
        <button
          class={`tab ${index === 0 ? "active" : ""}`}
          type="button"
          data-tab={trilha.id}
        >
          {trilha.nome}
        </button>
      ))}
    </div>

    <button
      class="tabs-arrow tabs-arrow-right"
      type="button"
      aria-label="Ver próximas trilhas"
    >
      ›
    </button>
  </div>

  <div class="tracks">
    {trilhas.map((trilha, index) => (
      <div
        class={`track-shell ${index === 0 ? "active" : ""}`}
        data-track-shell={trilha.id}
      >
        <button
          class="track-arrow track-arrow-left"
          type="button"
          aria-label="Ver palestra anterior"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15 5l-7 7 7 7" />
          </svg>
        </button>

        <div
          class={`track ${index === 0 ? "active" : ""}`}
          data-track={trilha.id}
        >
          {trilha.palestras.map((palestra) => (
            <TrilhaCard
              {...palestra}
              trilha={trilha.nome}
            />
          ))}
        </div>

        <button
          class="track-arrow track-arrow-right"
          type="button"
          aria-label="Ver próxima palestra"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    ))}
  </div>
</section>

<style>
  .trilhas-section {
    position: relative;
    overflow: hidden;
    padding: 70px 20px 90px;
    background:
      radial-gradient(
        circle at 8% 22%,
        rgba(0, 194, 100, 0.16),
        transparent 32%
      ),
      radial-gradient(
        circle at 92% 78%,
        rgba(6, 72, 82, 0.13),
        transparent 35%
      ),
      linear-gradient(
        135deg,
        #f9fdfc 0%,
        #e4f2f2 48%,
        #f3faf8 100%
      );
    font-family: "Raleway", sans-serif;
  }

  .trilhas-section::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 80px;
    z-index: 0;
    width: 980px;
    height: 700px;
    transform: translateX(-50%);
    background:
      radial-gradient(
        ellipse at center,
        rgba(0, 194, 100, 0.18) 0%,
        rgba(0, 194, 100, 0.08) 34%,
        transparent 70%
      );
    filter: blur(45px);
    pointer-events: none;
  }

  .trilhas-header,
  .tabs-wrapper,
  .tracks {
    position: relative;
    z-index: 1;
  }

  .trilhas-header {
    max-width: 1400px;
    margin: 0 auto;
  }

  .titulo-trilhas {
    width: min(760px, 90%);
    display: block;
    margin: 0 auto 42px;
  }

  .tabs-wrapper {
    width: min(1260px, 100%);
    margin: 0 auto 48px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tabs {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    overflow-x: auto;
    padding: 5px 3px 8px;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .tabs::-webkit-scrollbar {
    display: none;
  }

  .tab {
    flex: 0 0 auto;
    min-height: 42px;
    padding: 0 20px;
    border: 1px solid rgba(6, 72, 82, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: #064852;
    font: inherit;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    white-space: nowrap;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .tab:hover {
    transform: translateY(-2px);
    border-color: rgba(0, 194, 100, 0.5);
  }

  .tab.active {
    background: #064852;
    color: #00c264;
    border-color: #00c264;
    box-shadow: 0 12px 24px rgba(6, 72, 82, 0.14);
  }

  .tabs-arrow {
    flex: 0 0 auto;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1px solid rgba(6, 72, 82, 0.12);
    border-radius: 50%;
    background: #ffffff;
    color: #064852;
    font-family: Arial, sans-serif;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 10px 22px rgba(6, 72, 82, 0.1);
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      opacity 0.25s ease;
  }

  .tabs-arrow:hover:not(:disabled) {
    transform: scale(1.06);
    background: #00c264;
  }

  .tabs-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .track-shell {
    position: relative;
    display: none;
    width: 100%;
  }

  .track-shell.active {
    display: block;
  }

  .track {
    display: none;
    width: min(1200px, 100%);
    margin: 0 auto;
    justify-content: center;
    align-items: flex-start;
    flex-wrap: nowrap;
    gap: 40px;
  }

  .track.active {
    display: flex;
  }

  /* --- Setas Circulares --- */
  .track-arrow {
    position: absolute;
    top: 50%;
    z-index: 20;
    width: 44px;
    height: 44px;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1.5px solid rgba(0, 194, 100, 0.5);
    border-radius: 50%;
    background: rgba(6, 72, 82, 0.95);
    color: #00c264;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(8px);
    cursor: pointer;
    transform: translateY(-50%) scale(1);
    transition:
      transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
      background 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .track-arrow:hover:not(:disabled),
  .track-arrow:active:not(:disabled) {
    transform: translateY(-50%) scale(1.12);
    background: #00c264;
    color: #061827;
    border-color: #00c264;
    box-shadow: 0 0 20px rgba(0, 194, 100, 0.7);
  }

  .track-arrow svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .track-arrow-left {
    left: 8px;
  }

  .track-arrow-right {
    right: 8px;
  }

  .track:has(:global(.trilha-card.selected))
    :global(.trilha-card:not(.selected)) {
    opacity: 0.28;
    transform: scale(0.96);
    filter: saturate(0.65);
  }

  /* --- Mobile Layout & Alignment --- */
  @media (max-width: 900px) {
    .trilhas-section {
      padding: 55px 0 68px;
    }

    .trilhas-section::before {
      width: 720px;
      height: 540px;
      top: 60px;
      filter: blur(36px);
    }

    .titulo-trilhas {
      width: min(560px, 88%);
      margin-bottom: 30px;
    }

    .tabs-wrapper {
      width: 100%;
      box-sizing: border-box;
      gap: 7px;
      margin-bottom: 34px;
      padding: 0 10px;
    }

    .tabs {
      padding-block: 5px 9px;
    }

    .tabs-arrow {
      width: 34px;
      height: 34px;
      font-size: 25px;
    }

    .tab {
      min-height: 38px;
      padding: 0 16px;
      font-size: 10px;
    }

    /* As setas aparecem flutuando nas bordas no mobile */
    .track-shell.active.has-many .track-arrow.visible {
      display: inline-flex !important;
    }

    .track.active {
      justify-content: flex-start;
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      gap: 16px;
      
      /* Card = 290px; 50vw - 145px centraliza o primeiro e o último card exatamente na tela */
      padding: 12px calc(50vw - 145px) 28px;
      scroll-padding-inline: calc(50vw - 145px);

      scroll-behavior: smooth;
      scroll-snap-type: x mandatory;
      box-sizing: border-box;
    }

    .track.active::-webkit-scrollbar {
      display: none;
    }

    .track.active :global(.trilha-card) {
      scroll-snap-align: center;
      scroll-snap-stop: always;
      flex: 0 0 290px !important;
      width: 290px !important;
      max-width: 290px !important;
      box-sizing: border-box;
    }
  }

  @media (max-width: 480px) {
    .trilhas-section {
      padding-top: 48px;
    }

    .titulo-trilhas {
      width: min(500px, 90%);
      margin-bottom: 26px;
    }

    .tabs-wrapper {
      padding-inline: 8px;
    }

    .tabs-arrow {
      width: 32px;
      height: 32px;
      font-size: 23px;
    }

    .tab {
      min-height: 36px;
      padding: 0 14px;
      font-size: 9px;
    }
  }

  @media (min-width: 901px) {
    .track-arrow {
      display: none !important;
    }
  }
</style>

<script>
  function setupTrackNavigation(section) {
    const trackShells = section.querySelectorAll('.track-shell');
    const tabs = section.querySelectorAll('.tab');
    const tabsContainer = section.querySelector('.tabs');
    const tabsLeft = section.querySelector('.tabs-arrow-left');
    const tabsRight = section.querySelector('.tabs-arrow-right');

    if (!tabsContainer) return;

    // Navegação das abas superiores
    const updateTabArrows = () => {
      const maxScroll = tabsContainer.scrollWidth - tabsContainer.clientWidth;
      if (tabsLeft instanceof HTMLButtonElement) {
        tabsLeft.disabled = tabsContainer.scrollLeft <= 4;
      }
      if (tabsRight instanceof HTMLButtonElement) {
        tabsRight.disabled = tabsContainer.scrollLeft >= maxScroll - 4;
      }
    };

    tabsLeft?.addEventListener('click', () => {
      tabsContainer.scrollBy({ left: -760, behavior: 'smooth' });
    });

    tabsRight?.addEventListener('click', () => {
      tabsContainer.scrollBy({ left: 760, behavior: 'smooth' });
    });

    tabsContainer.addEventListener('scroll', updateTabArrows, { passive: true });
    updateTabArrows();

    function obterCards(track) {
      return Array.from(track.querySelectorAll('.trilha-card'));
    }

    function obterIndiceAtivo(track) {
      const cards = obterCards(track);
      if (cards.length === 0) return 0;

      const containerCenter = track.scrollLeft + track.clientWidth / 2;
      let activeIndex = 0;
      let menorDistancia = Infinity;

      cards.forEach((card, index) => {
        const cardCenter = card.offsetLeft + card.offsetWidth / 2;
        const distancia = Math.abs(cardCenter - containerCenter);
        if (distancia < menorDistancia) {
          menorDistancia = distancia;
          activeIndex = index;
        }
      });

      return activeIndex;
    }

    function navegarParaCard(track, targetIndex) {
      const cards = obterCards(track);
      const card = cards[targetIndex];
      if (!card) return;

      // scrollIntoView com inline: 'center' faz o navegador usar o alinhamento perfeito de CSS Snap
      card.scrollIntoView({
        behavior: 'smooth',
        block: 'nearest',
        inline: 'center'
      });
    }

    function atualizarSetas(shell) {
      const track = shell.querySelector('.track');
      if (!(track instanceof HTMLElement)) return;

      const cards = obterCards(track);
      const leftArrow = shell.querySelector('.track-arrow-left');
      const rightArrow = shell.querySelector('.track-arrow-right');

      // 1 Card -> Oculta AMBAS
      if (cards.length <= 1) {
        shell.classList.remove('has-many');
        leftArrow?.classList.remove('visible');
        rightArrow?.classList.remove('visible');
        return;
      }

      shell.classList.add('has-many');
      const activeIndex = obterIndiceAtivo(track);

      // Regras de Exibição das setas
      if (leftArrow instanceof HTMLElement) {
        if (activeIndex > 0) {
          leftArrow.classList.add('visible');
        } else {
          leftArrow.classList.remove('visible');
        }
      }

      if (rightArrow instanceof HTMLElement) {
        if (activeIndex < cards.length - 1) {
          rightArrow.classList.add('visible');
        } else {
          rightArrow.classList.remove('visible');
        }
      }
    }

    trackShells.forEach((shell) => {
      const track = shell.querySelector('.track');
      const leftArrow = shell.querySelector('.track-arrow-left');
      const rightArrow = shell.querySelector('.track-arrow-right');

      if (!(track instanceof HTMLElement)) return;

      leftArrow?.addEventListener('click', (e) => {
        e.preventDefault();
        const activeIndex = obterIndiceAtivo(track);
        if (activeIndex > 0) {
          navegarParaCard(track, activeIndex - 1);
        }
      });

      rightArrow?.addEventListener('click', (e) => {
        e.preventDefault();
        const activeIndex = obterIndiceAtivo(track);
        const cards = obterCards(track);
        if (activeIndex < cards.length - 1) {
          navegarParaCard(track, activeIndex + 1);
        }
      });

      track.addEventListener('scroll', () => {
        window.requestAnimationFrame(() => atualizarSetas(shell));
      }, { passive: true });

      atualizarSetas(shell);
    });

    // Troca de Abas
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        const selectedShell = section.querySelector(`[data-track-shell="${target}"]`);
        const selectedTrack = section.querySelector(`[data-track="${target}"]`);

        tabs.forEach((item) => item.classList.remove('active'));
        trackShells.forEach((shell) => shell.classList.remove('active'));
        section.querySelectorAll('.track').forEach((t) => t.classList.remove('active'));

        tab.classList.add('active');

        if (selectedShell instanceof HTMLElement && selectedTrack instanceof HTMLElement) {
          selectedShell.classList.add('active');
          selectedTrack.classList.add('active');
          
          window.requestAnimationFrame(() => {
            navegarParaCard(selectedTrack, 0);
            atualizarSetas(selectedShell);
          });
        }

        tab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      });
    });

    window.addEventListener('resize', () => {
      const activeShell = section.querySelector('.track-shell.active');
      if (activeShell instanceof HTMLElement) {
        atualizarSetas(activeShell);
      }
    });
  }

  function initTrilhas() {
    document.querySelectorAll('.trilhas-section').forEach((section) => {
      if (!(section instanceof HTMLElement)) return;
      if (section.dataset.ready === 'true') return;
      section.dataset.ready = 'true';
      setupTrackNavigation(section);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTrilhas, { once: true });
  } else {
    initTrilhas();
  }

  document.addEventListener('astro:page-load', initTrilhas);
</script>