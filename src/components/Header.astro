<header class="site-header">
  <a href="/" class="logo" aria-label="Página inicial do PARAR Summit 26">
    <img src="/logos/logo-summit.svg" alt="PARAR Summit 26" />
  </a>

    <div class="header-actions">
    <a
      class="ticket-button"
      href="https://www.sympla.com.br/evento/parar-summit-26/3273575"
      target="_blank"
      rel="noopener noreferrer"
    >
      Ingressos
    </a>

  <nav class="menu" id="main-menu">
    <a href="#trilhas">Trilhas de conteúdo</a>
    <a href="#plenaria">Plenária principal</a>
    <a href="#parar-awards">Inscrições PARAR Awards</a>
    <a href="#mapa-evento">Mapa do evento</a>
    <a href="#patrocinio">Patrocinadores</a>
  </nav>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="main-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&display=swap');

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
  }

  .site-header {
    font-family: 'Raleway', sans-serif;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9999;

    width: 100%;
    box-sizing: border-box;

    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 32px;

    padding: 28px 6%;

    background: #00c264;

    transition:
      padding 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .site-header.scrolled {
    background: rgba(2, 70, 83, 0.48);

    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);

    border-bottom: 1px solid rgba(255, 255, 255, 0.08);

    box-shadow:
      0 8px 28px rgba(0, 0, 0, 0.12);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo img {
    height: 42px;
    display: block;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .ticket-button {
    font-family: 'Raleway', sans-serif;
    min-height: 46px;
    padding: 0 24px;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    border-radius: 6px;

    background: #074157;
    color: #ffffff;

    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;

    font-size: 14px;
    font-weight: 900;

    transition:
      transform 0.25s ease,
      background 0.25s ease;
  }

  .ticket-button:hover {
    background: #06353e;
    transform: translateY(-2px);
  }

  .menu {
    justify-self: end;

    display: flex;
    align-items: center;
    gap: 34px;

    padding: 22px 28px;

    border-radius: 12px;

    background: rgba(6, 72, 82, 0.14);
  }

  .menu a {
    font-family: 'Raleway', sans-serif;
    color: #ffffff;

    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;

    font-size: 14px;
    font-weight: 900;
  }

  .menu a:hover {
    opacity: 0.78;
  }

  .menu-toggle {
    width: 48px;
    height: 48px;

    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 6px;

    padding: 0;
    border: 0;
    border-radius: 4px;

    background: rgba(6, 72, 82, 0.18);

    cursor: pointer;
  }

  .menu-toggle span {
    width: 26px;
    height: 3px;

    border-radius: 999px;

    background: #ffffff;

    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  @media (max-width: 1100px) and (min-width: 901px) {
    .site-header {
      gap: 20px;
      padding-inline: 4%;
    }

    .menu {
      gap: 20px;
      padding: 20px;
    }

    .menu a,
    .ticket-button {
      font-size: 12px;
    }

    .ticket-button {
      padding-inline: 18px;
    }
  }

  @media (max-width: 900px) {
    .site-header {
      display: flex;
      flex-direction: column;
      justify-content: center;

      gap: 12px;
      padding: 14px 18px;
    }

    .logo {
      width: 100%;
      justify-content: center;
    }

    .logo img {
      height: 38px;
      max-width: 220px;
    }

    .header-actions {
      width: 100%;
      justify-content: center;
      gap: 10px;
    }

    .ticket-button {
      min-width: 120px;
      min-height: 40px;
      padding: 0 18px;

      border-radius: 3px;

      background: rgba(6, 72, 82, 0.18);

      font-size: 13px;
      font-weight: 700;
    }

    .menu-toggle {
      width: 40px;
      height: 40px;

      display: flex;

      border-radius: 3px;
    }

    .menu-toggle span {
      width: 20px;
      height: 2px;
    }

    .menu {
      position: absolute;
      top: calc(100% + 8px);
      left: 16px;
      right: 16px;

      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0;

      padding: 10px;

      border-radius: 14px;

      background: rgba(2, 70, 83, 0.97);

      box-shadow:
        0 18px 40px rgba(0, 0, 0, 0.24);

      opacity: 0;
      visibility: hidden;
      pointer-events: none;

      transform: translateY(-12px);

      transition:
        opacity 0.3s ease,
        transform 0.3s ease,
        visibility 0.3s ease;
    }

    .menu.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;

      transform: translateY(0);
    }

    .menu a {
      padding: 16px 14px;

      border-radius: 10px;

      text-align: center;
      font-size: 13px;
    }

    .menu a:hover {
      background: rgba(255, 255, 255, 0.08);
      opacity: 1;
    }

    .menu-toggle.open span:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    .menu-toggle.open span:nth-child(2) {
      opacity: 0;
    }

    .menu-toggle.open span:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }
  }

  @media (max-width: 430px) {
    .site-header {
      gap: 10px;
      padding: 12px 14px;
    }

    .logo img {
      height: 34px;
      max-width: 205px;
    }

    .ticket-button {
      min-width: 108px;
      min-height: 36px;
      padding-inline: 15px;

      font-size: 12px;
    }

    .menu-toggle {
      width: 36px;
      height: 36px;
    }

    .menu-toggle span {
      width: 19px;
    }
  }
</style>

<script>
  function iniciarHeader() {
    const header = document.querySelector('.site-header');
    const toggle = document.querySelector('.menu-toggle');
    const menu = document.querySelector('.menu');
    const numeros = document.querySelector('#numeros');

    if (!(header instanceof HTMLElement)) return;

    function fecharMenu() {
      if (!(toggle instanceof HTMLButtonElement)) return;
      if (!(menu instanceof HTMLElement)) return;

      menu.classList.remove('open');
      toggle.classList.remove('open');

      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Abrir menu');
    }

    if (
      toggle instanceof HTMLButtonElement &&
      menu instanceof HTMLElement &&
      toggle.dataset.ready !== 'true'
    ) {
      toggle.dataset.ready = 'true';

      toggle.addEventListener('click', () => {
        const isOpen = menu.classList.toggle('open');

        toggle.classList.toggle('open', isOpen);
        toggle.setAttribute(
          'aria-expanded',
          String(isOpen)
        );
        toggle.setAttribute(
          'aria-label',
          isOpen ? 'Fechar menu' : 'Abrir menu'
        );
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', fecharMenu);
      });

      document.addEventListener('click', (event) => {
        const target = event.target;

        if (
          target instanceof Element &&
          !target.closest('.site-header')
        ) {
          fecharMenu();
        }
      });
    }

    function atualizarHeader() {
      if (!(numeros instanceof HTMLElement)) {
        header.classList.remove('scrolled');
        return;
      }

      const fimDosNumeros =
        numeros.offsetTop +
        numeros.offsetHeight -
        header.offsetHeight;

      header.classList.toggle(
        'scrolled',
        window.scrollY > fimDosNumeros
      );
    }

    function ajustarEspacoDoHeader() {
      document.body.style.paddingTop =
        `${header.offsetHeight}px`;
    }

    atualizarHeader();
    ajustarEspacoDoHeader();

    window.addEventListener(
      'scroll',
      atualizarHeader,
      { passive: true }
    );

    window.addEventListener('resize', () => {
      ajustarEspacoDoHeader();
      atualizarHeader();
    });
  }

  iniciarHeader();

  document.addEventListener(
    'astro:page-load',
    iniciarHeader
  );
</script>