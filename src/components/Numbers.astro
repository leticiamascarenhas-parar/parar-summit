<section id="numeros" class="numbers-section">

  <div class="numbers-divider numbers-divider--top" aria-hidden="true"></div>

  <div class="numbers-decor numbers-decor--bl" aria-hidden="true">
    <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="200" cy="200" r="60" stroke="#00d267" stroke-width="3" />
      <circle cx="200" cy="200" r="110" stroke="#00d267" stroke-width="2" opacity="0.7" />
      <circle cx="200" cy="200" r="160" stroke="#00e6a8" stroke-width="2" opacity="0.45" />
      <circle cx="200" cy="200" r="200" stroke="#00c264" stroke-width="1.5" opacity="0.25" />
    </svg>
  </div>

  <div class="numbers-decor numbers-decor--tr" aria-hidden="true">
    <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="200" cy="200" r="55" stroke="#00d267" stroke-width="3" />
      <circle cx="200" cy="200" r="100" stroke="#00d267" stroke-width="2" opacity="0.7" />
      <circle cx="200" cy="200" r="150" stroke="#00e6a8" stroke-width="2" opacity="0.4" />
      <circle cx="200" cy="200" r="190" stroke="#00c264" stroke-width="1.5" opacity="0.22" />
    </svg>
  </div>

  <div class="numbers-inner">

    <div class="numbers-gallery">
        <img src="/images/mosaico.png" alt="Fotos PARAR Summit" />
        </div>

    <div class="numbers-content">
      <div class="number-item">
        <span class="counter" data-target="40" data-prefix="+">0</span>
        <p>Expositores</p>
      </div>

      <div class="number-item">
        <span class="counter" data-target="1400" data-prefix="+">0</span>
        <p>Profissionais Presentes</p>
      </div>

      <div class="number-highlight">
        <small>E A SUPER NOVIDADE</small>
        <strong>
          <span class="counter" data-target="15" data-prefix="+">0</span>
          TRILHAS DE CONTEÚDO
        </strong>
        <p>SIMULTÂNEAS</p>
      </div>

      <div class="number-item">
        <span class="counter" data-target="18" data-prefix="+" data-suffix="H">0</span>
        <p>Conteúdo relevante</p>
      </div>

      <div class="number-item">
        <span class="counter" data-target="40" data-prefix="+">0</span>
        <p>Palestrantes</p>
      </div>
    </div>

  </div>

  <div class="numbers-divider numbers-divider--bottom" aria-hidden="true"></div>

</section>

<style>
  .numbers-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;

    padding: 88px 6%;
    font-family: "Raleway", sans-serif;

    background:
      radial-gradient(circle at 12% 20%, rgba(255, 255, 255, 0.10), transparent 30%),
      radial-gradient(circle at 90% 80%, rgba(255, 255, 255, 0.08), transparent 32%),
      radial-gradient(ellipse at 50% 40%, #14d878 0%, #00c264 55%, #009850 100%);
  }

  .numbers-inner {
    position: relative;
    z-index: 1;
    width: min(1280px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(500px, 0.95fr);
    gap: 42px;
    align-items: center;
  }

  /* ---------- linhas divisórias ---------- */

  .numbers-divider {
    position: absolute;
    left: 0;
    right: 0;
    height: 4px;
    z-index: 3;
    background: linear-gradient(
      90deg,
      transparent 0%,
      #00d267 12%,
      #00d267 88%,
      transparent 100%
    );
    box-shadow:
      0 0 10px 2px rgba(0, 210, 103, 0.65),
      0 0 34px 8px rgba(0, 210, 103, 0.28);
  }

  .numbers-divider--top {
    top: 0;
  }

  .numbers-divider--bottom {
    bottom: 0;
  }

  /* ---------- decoração de cantos ---------- */

  .numbers-decor {
    position: absolute;
    width: 420px;
    height: 420px;
    z-index: 0;
    pointer-events: none;
  }

  .numbers-decor--bl {
    left: -140px;
    bottom: -140px;
  }

  .numbers-decor--tr {
    right: -140px;
    top: -60px;
  }

  .numbers-decor svg {
    width: 100%;
    height: 100%;
  }

  .numbers-gallery {
    padding: 10px;
    border-radius: 24px;
    background: rgba(6, 38, 52, 0.18);
    border: 1px solid rgba(6, 38, 52, 0.25);
  }

  .numbers-gallery img {
    width: 100%;
    display: block;
    border-radius: 16px;
  }

  .numbers-content {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    text-align: center;
  }

  .number-item {
    min-height: 102px;
    padding: 18px 14px;

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    border: 1px solid rgba(6, 38, 52, 0.18);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(6px);
    font-family: "Raleway", sans-serif;
    transition: border-color .25s ease, background .25s ease;
  }

  .number-item:hover {
    border-color: rgba(6, 38, 52, 0.35);
    background: rgba(255, 255, 255, 0.72);
  }

  .number-item .counter {
    display: block;
    color: #064852;
    font-size: clamp(38px, 3.4vw, 54px);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -1.5px;
    text-shadow: none;
  }

  .number-item p {
    margin: 10px 0 0;
    color: #064852;
    opacity: 0.85;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 700;
    text-transform: uppercase;
    font-family:'Oswald',sans-serif;
  }

  .number-highlight {
    grid-column: 1 / -1;
    padding: 22px 20px;
    border-radius: 18px;

    background: #064852;

    color: #ffffff;
    box-shadow: 0 0 0 1px rgba(6, 38, 52, 0.4), 0 20px 45px rgba(6, 38, 52, 0.3);
  }

  .number-highlight small {
    display: block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.4px;
    color: rgba(255, 255, 255, 0.75);
  }

  .number-highlight strong {
    display: block;
    margin-top: 8px;
    font-size: clamp(24px, 2.5vw, 34px);
    line-height: 1.08;
    font-weight: 900;
    color: #ffffff;
  }

  .number-highlight strong .counter {
    margin-right: 5px;
    color: #00e67a;
    text-shadow: none;
  }

  .number-highlight p {
    margin: 7px 0 0;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.8px;
    color: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 980px) {
    .numbers-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .numbers-gallery,
    .numbers-content {
      width: min(720px, 100%);
      margin: 0 auto;
    }
  }

  @media (max-width: 600px) {
    .numbers-section {
      padding: 60px 18px;
    }

    .numbers-content {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .number-item {
      min-height: 96px;
      padding: 16px 10px;
      border-radius: 15px;
    }

    .number-item .counter {
      font-size: 36px;
      letter-spacing: -1px;
    }

    .number-item p {
      font-size: 10px;
    }

    .number-highlight {
      padding: 20px 14px;
      border-radius: 16px;
    }

    .number-highlight strong {
      font-size: 23px;
    }
  }
</style>

<script>
  function iniciarContadores() {
    const section = document.querySelector('.numbers-section');

    if (!(section instanceof HTMLElement)) return;
    if (section.dataset.ready === 'true') return;

    section.dataset.ready = 'true';

    const counters = Array.from(
      section.querySelectorAll('.counter')
    ).filter((item) => item instanceof HTMLElement);

    let animationFrames = [];

    function cancelarAnimacoes() {
      animationFrames.forEach((frame) => {
        cancelAnimationFrame(frame);
      });

      animationFrames = [];
    }

    function zerarContadores() {
      cancelarAnimacoes();

      counters.forEach((counter) => {
        counter.textContent = '0';
      });
    }

    function animarContadores() {
      cancelarAnimacoes();

      counters.forEach((counter) => {
        const target = Number(counter.dataset.target);
        const prefix = counter.dataset.prefix || '';
        const suffix = counter.dataset.suffix || '';
        const duration = 1600;
        const start = performance.now();

        function atualizar(now) {
          const progress = Math.min(
            (now - start) / duration,
            1
          );

          const easedProgress =
            1 - Math.pow(1 - progress, 3);

          const current = Math.floor(
            easedProgress * target
          );

          counter.textContent =
            prefix +
            current.toLocaleString('pt-BR') +
            suffix;

          if (progress < 1) {
            const frame = requestAnimationFrame(atualizar);
            animationFrames.push(frame);
          } else {
            counter.textContent =
              prefix +
              target.toLocaleString('pt-BR') +
              suffix;
          }
        }

        const frame = requestAnimationFrame(atualizar);
        animationFrames.push(frame);
      });
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          zerarContadores();
          animarContadores();
        } else {
          zerarContadores();
        }
      },
      {
        threshold: 0.35
      }
    );

    observer.observe(section);
  }

  iniciarContadores();

  document.addEventListener(
    'astro:page-load',
    iniciarContadores
  );
</script>